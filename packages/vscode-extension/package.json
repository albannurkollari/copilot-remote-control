{
  "name": "remote-copilot-host",
  "displayName": "Remote Copilot Host",
  "version": "1.0.0",
  "description": "Control GitHub Copilot remotely through a WebSocket relay host.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "automation",
    "controller",
    "copilot",
    "host",
    "relay",
    "remote"
  ],
  "homepage": "https://github.com/albannurkollari/copilot-remote-control/tree/main/packages/vscode-extension",
  "bugs": {
    "url": "https://github.com/albannurkollari/copilot-remote-control/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/albannurkollari/copilot-remote-control.git",
    "directory": "packages/vscode-extension"
  },
  "publisher": "erenndriel",
  "files": [
    "assets",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/extension.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "node --eval \"console.log('Run this package in the VS Code extension host during development.')\"",
    "build": "tsup",
    "clean": "rm -rfd dist",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "vscode:prepublish": "pnpm run build",
    "package": "node ./scripts/vsce.ts --package",
    "publish:marketplace": "node ./scripts/vsce.ts --publish"
  },
  "devDependencies": {
    "@remote-copilot/shared": "workspace:*",
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.109.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "remoteCopilot.authorizeCopilotAccess",
        "title": "Remote Copilot: Authorize Copilot Access"
      },
      {
        "command": "remoteCopilot.showRelayOutput",
        "title": "Remote Copilot: Show Relay Output"
      },
      {
        "command": "remoteCopilot.showRemoteSessions",
        "title": "Remote Copilot: Show Remote Sessions"
      },
      {
        "command": "remoteCopilot.clearRemoteSessions",
        "title": "Remote Copilot: Clear Remote Sessions"
      },
      {
        "command": "remoteCopilot.reconnectRelay",
        "title": "Remote Copilot: Reconnect Relay"
      }
    ],
    "configuration": {
      "title": "Remote Copilot",
      "properties": {
        "remoteCopilot.clientId": {
          "type": "string",
          "default": "default",
          "description": "Logical client ID used to register this VS Code bridge with the relay server."
        },
        "remoteCopilot.relayUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:8787/",
          "description": "WebSocket relay URL used by the remote Copilot host."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui"
  ],
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  }
}
