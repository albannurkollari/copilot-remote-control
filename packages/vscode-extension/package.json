{
  "name": "@remote-copilot/vscode-extension",
  "displayName": "Remote Copilot Bridge",
  "version": "0.0.1",
  "private": true,
  "description": "Bridge Discord prompts to GitHub Copilot through a WebSocket relay.",
  "categories": [
    "Other"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/extension.js",
  "imports": {
    "#discord/*": "../discord-bot/src/*",
    "#relay/*": "../relay-server/src/*",
    "#shared/*": "../shared/src/*",
    "#extension/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "node --eval \"console.log('Run this package in the VS Code extension host during development.')\"",
    "build": "tsup",
    "clean": "rm -rfd dist",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@remote-copilot/shared": "workspace:*",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-electron": "^2.5.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "remoteCopilot.authorizeCopilotAccess",
        "title": "Remote Copilot: Authorize Copilot Access"
      },
      {
        "command": "remoteCopilot.showRelayOutput",
        "title": "Remote Copilot: Show Relay Output"
      },
      {
        "command": "remoteCopilot.showRemoteSessions",
        "title": "Remote Copilot: Show Remote Sessions"
      },
      {
        "command": "remoteCopilot.clearRemoteSessions",
        "title": "Remote Copilot: Clear Remote Sessions"
      },
      {
        "command": "remoteCopilot.reconnectRelay",
        "title": "Remote Copilot: Reconnect Relay"
      }
    ],
    "configuration": {
      "title": "Remote Copilot",
      "properties": {
        "remoteCopilot.clientId": {
          "type": "string",
          "default": "default",
          "description": "Logical client ID used to register this VS Code bridge with the relay server."
        },
        "remoteCopilot.relayUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:8787/",
          "description": "WebSocket relay URL used by the remote Copilot bridge."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.105.0"
  }
}
