{
  "name": "@remote-copilot/shared",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "imports": {
    "#discord/*": "../discord-bot/src/*",
    "#relay/*": "../relay-server/src/*",
    "#shared/*": "./src/*",
    "#extension/*": "../vscode-extension/src/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "node src/index.ts",
    "build": "tsup",
    "clean": "rm -rfd dist",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --project @remote-copilot/shared"
  }
}
