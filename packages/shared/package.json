{
  "name": "@remote-copilot/shared",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#discord/*": "./../discord-bot/src/*",
    "#relay/*": "./../relay-server/src/*",
    "#shared/*": "./src/*",
    "#extension/*": "./../vscode-extension/src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "node src/index.ts",
    "build": "tsup",
    "clean": "node --eval \"import('node:fs/promises').then((fs) => fs.rm('dist', { recursive: true, force: true }))\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
