# =============================================================================
# Remote Copilot environment template
# =============================================================================
# Generate concrete files with:
#   pnpm env:generate
#   pnpm env:generate:dev
#   pnpm env:generate:prod

APP_ENV={{APP_ENV}}

# =============================================================================
# Relay server
# =============================================================================
RELAY_HOST={{RELAY_HOST}}
RELAY_PORT={{RELAY_PORT}}
RELAY_PATH={{RELAY_PATH}}
RELAY_URL={{RELAY_URL}}
RELAY_LOG={{RELAY_LOG}}
REMOTE_COPILOT_SHARED_SECRET={{REMOTE_COPILOT_SHARED_SECRET}}

# =============================================================================
# Discord bot
# =============================================================================
DISCORD_TOKEN=replace-with-your-bot-token
DISCORD_APPLICATION_ID=replace-with-your-discord-application-id
DISCORD_GUILD_ID=replace-with-your-discord-server-id
DISCORD_STREAM_UPDATE_MS=1200
REMOTE_COPILOT_CLIENT_ID={{REMOTE_COPILOT_CLIENT_ID}}

# =============================================================================
# VS Code extension reference values
# =============================================================================
# The extension reads these as VS Code settings, not environment variables.
# Copy these values into your VS Code settings.json:
#   "remoteCopilot.clientId": "{{REMOTE_COPILOT_CLIENT_ID}}"
#   "remoteCopilot.relayUrl": "{{RELAY_URL}}"
#   "remoteCopilot.sharedSecret": "{{REMOTE_COPILOT_SHARED_SECRET}}"

VSCODE_REMOTE_COPILOT_CLIENT_ID={{REMOTE_COPILOT_CLIENT_ID}}
VSCODE_REMOTE_COPILOT_RELAY_URL={{RELAY_URL}}
VSCODE_REMOTE_COPILOT_SHARED_SECRET={{REMOTE_COPILOT_SHARED_SECRET}}
