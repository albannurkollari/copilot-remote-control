{
  "name": "remote-copilot",
  "version": "1.2.2",
  "private": true,
  "description": "Remote control system for GitHub Copilot Chat via Discord using a VSCode extension bridge and WebSocket relay.",
  "keywords": [
    "AI",
    "Agentic AI",
    "Discord",
    "TypeScript",
    "VSCode",
    "automation",
    "extension",
    "remote control"
  ],
  "homepage": "https://github.com/albannurkollari/copilot-remote-control",
  "bugs": {
    "url": "https://github.com/albannurkollari/copilot-remote-control/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Alban Nurkollari",
    "email": "albannurkollari@gmail.com"
  },
  "contributors": [
    {
      "name": "Alban Nurkollari",
      "email": "albannurkollari@gmail.com",
      "url": "https://github.com/albannurkollari"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albannurkollari/copilot-remote-control.git"
  },
  "type": "module",
  "scripts": {
    "postinstall": "pnpm dev:init",
    "dev": "pnpm -r --parallel run dev",
    "dev:init": "pnpm --filter copilot-rc dev init",
    "dev:stack": "pnpm --filter copilot-rc dev start",
    "dev:bot": "pnpm --filter @remote-copilot/discord-bot dev",
    "dev:server": "pnpm --filter @remote-copilot/relay-server dev",
    "build": "pnpm -r run build",
    "verify:copilot-rc-built": "pnpm --filter copilot-rc run smoke:built",
    "clean": "pnpm -r run clean",
    "test": "vitest run",
    "coverage": "pnpm vitest run --coverage",
    "env:generate": "node scripts/generate-env.ts --all",
    "env:generate:dev": "node scripts/generate-env.ts --dev",
    "env:generate:prod": "node scripts/generate-env.ts --prod",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "pnpm -r run typecheck",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "publish:extension": "pnpm --dir packages/vscode-extension run publish:marketplace"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "picocolors": "^1.1.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "beta",
        "prerelease": true
      }
    ],
    "tagFormat": "v${version}",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "angular",
          "releaseRules": [
            {
              "type": "refactor",
              "release": "minor"
            },
            {
              "type": "chore",
              "release": false
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "node scripts/sync-release-version.ts ${nextRelease.version}"
        }
      ],
      [
        "@semantic-release/npm",
        {
          "pkgRoot": "packages/copilot-rc"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "packages/copilot-rc/package.json",
            "packages/discord-bot/package.json",
            "packages/relay-server/package.json",
            "packages/shared/package.json",
            "packages/vscode-extension/package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "@vscode/vsce>minimatch": "3.1.4",
      "undici@<6.23.0": ">=6.23.0",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@<3.1.4": ">=3.1.4"
    }
  }
}
