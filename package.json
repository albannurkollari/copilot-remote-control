{
  "name": "remote-copilot",
  "version": "0.0.1",
  "private": true,
  "description": "Remote control system for GitHub Copilot Chat via Discord using a VSCode extension bridge and WebSocket relay.",
  "keywords": [
    "AI",
    "Agentic AI",
    "Discord",
    "TypeScript",
    "VSCode",
    "automation",
    "extension",
    "remote control"
  ],
  "homepage": "https://github.com/albannurkollari/copilot-remote-control",
  "bugs": {
    "url": "https://github.com/albannurkollari/copilot-remote-control/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Alban Nurkollari",
    "email": "albannurkollari@gmail.com"
  },
  "contributors": [
    {
      "name": "Alban Nurkollari",
      "email": "albannurkollari@gmail.com",
      "url": "https://github.com/albannurkollari"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albannurkollari/copilot-remote-control.git"
  },
  "type": "module",
  "imports": {
    "#discord/*": "./packages/discord-bot/src/*",
    "#relay/*": "./packages/relay-server/src/*",
    "#shared/*": "./packages/shared/src/*",
    "#extension/*": "./packages/vscode-extension/src/*"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "test": "vitest run",
    "coverage": "pnpm vitest run --coverage",
    "env:generate": "node scripts/env.ts --all",
    "env:generate:dev": "node scripts/env.ts --dev",
    "env:generate:prod": "node scripts/env.ts --prod",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "pnpm -r run typecheck",
    "tsconfig:paths": "node scripts/tsconfig.ts --syncAliases",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "dependencies": {
    "oxfmt": "^0.36.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "3.2.4",
    "lefthook": "^2.1.3",
    "oxlint": "^1.51.0",
    "picocolors": "^1.1.1",
    "semantic-release": "^24.2.8",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "beta",
        "prerelease": true
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "angular",
          "releaseRules": [
            {
              "type": "refactor",
              "release": "minor"
            },
            {
              "type": "chore",
              "release": false
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "verifyConditionsCmd": "pnpm lint && pnpm fmt:check && pnpm typecheck && pnpm test && pnpm build"
        }
      ],
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "pnpm-lock.yaml"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10"
    }
  },
  "engines": {
    "node": ">=24"
  }
}
